# Local development standard environment.
# Copy to repo root as .env.local. Do not commit .env.local.

# Odoo connection
ODOO_URL=http://localhost:8069
ODOO_DB=odoo19_admin
ODOO_LOGIN=admin
ODOO_PASSWORD=admin
ODOO_FALLBACK_URLS=
ODOO_RPC_TIMEOUT_MS=30000

# Session security
SESSION_SECRET=replace-this-with-a-long-random-secret-at-least-32-chars
SESSION_COOKIE_SECURE=false

# App public URL
# APP_BASE_URL is the canonical value used by server-side URL generation.
APP_BASE_URL=http://localhost:3000
APP_TIME_ZONE=Asia/Ulaanbaatar
NEXT_PUBLIC_APP_TITLE=Хот тохижилтын удирдлагын төв

# Legacy aliases. Keep empty unless a deployment platform requires them.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=

# Push notifications
# Generate VAPID keys when enabling real browser push.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.invalid

# WRS report integration
WRS_REPORT_URL=http://wrs.ubservice.mn/ReportViewer_DetailView/66683522-e7a2-41ec-bce4-f5123a09485c
WRS_REPORT_LOGIN=replace-with-wrs-login
WRS_REPORT_PASSWORD=replace-with-wrs-password
WRS_SYNC_TOKEN=replace-with-a-strong-shared-token
WRS_REPORT_BRANCH_NAME=Морингийн энгэрийн төвлөрсөн хогийн цэг

# Optional Odoo model overrides for legacy fleet repair deployments.
FLEET_REPAIR_MODEL=
FLEET_REPAIR_QUOTE_MODEL=

