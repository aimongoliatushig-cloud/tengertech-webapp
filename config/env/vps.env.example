# VPS / staging / production standard environment.
# Copy to the deployed web app environment as .env. Do not commit real secrets.

# Odoo connection
ODOO_URL=https://CHANGE_ME_ODOO_DOMAIN_OR_IP
ODOO_DB=CHANGE_ME_ODOO_DATABASE
ODOO_LOGIN=CHANGE_ME_ODOO_LOGIN
ODOO_PASSWORD=CHANGE_ME_ODOO_PASSWORD
ODOO_FALLBACK_URLS=
ODOO_RPC_TIMEOUT_MS=30000

# Session security
# Generate with: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
SESSION_COOKIE_SECURE=true

# App public URL
# Must be the external HTTPS URL users open in the browser.
APP_BASE_URL=https://CHANGE_ME_WEB_APP_DOMAIN
APP_TIME_ZONE=Asia/Ulaanbaatar
NEXT_PUBLIC_APP_TITLE=Хот тохижилтын удирдлагын төв

# Legacy aliases. Prefer leaving these empty; APP_BASE_URL is canonical.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=

# Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:CHANGE_ME_ADMIN_EMAIL

# WRS report integration
WRS_REPORT_URL=http://wrs.ubservice.mn/ReportViewer_DetailView/66683522-e7a2-41ec-bce4-f5123a09485c
WRS_REPORT_LOGIN=CHANGE_ME_WRS_LOGIN
WRS_REPORT_PASSWORD=CHANGE_ME_WRS_PASSWORD

# Shared token for WRS sync API. Generate with: openssl rand -base64 48
WRS_SYNC_TOKEN=CHANGE_ME_LONG_RANDOM_SYNC_TOKEN
WRS_REPORT_BRANCH_NAME=Морингийн энгэрийн төвлөрсөн хогийн цэг

# Optional Odoo model overrides for legacy fleet repair deployments.
FLEET_REPAIR_MODEL=
FLEET_REPAIR_QUOTE_MODEL=

