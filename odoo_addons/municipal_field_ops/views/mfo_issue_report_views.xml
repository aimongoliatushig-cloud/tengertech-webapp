<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mfo_issue_report_list" model="ir.ui.view">
        <field name="name">mfo.issue.report.list</field>
        <field name="model">mfo.issue.report</field>
        <field name="arch" type="xml">
            <list string="Хяналтын тайлан" decoration-success="state == 'resolved'" decoration-danger="severity in ('high', 'critical')">
                <field name="report_datetime"/>
                <field name="name"/>
                <field name="execution_id"/>
                <field name="stop_line_id"/>
                <field name="issue_type"/>
                <field name="severity"/>
                <field name="reported_by"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_mfo_issue_report_form" model="ir.ui.view">
        <field name="name">mfo.issue.report.form</field>
        <field name="model">mfo.issue.report</field>
        <field name="arch" type="xml">
            <form string="Хяналтын тайлан">
                <header>
                    <button name="action_resolve" string="Шийдвэрлэх" type="object" class="btn-primary" invisible="state == 'resolved'"/>
                    <button name="action_cancel" string="Цуцлах" type="object" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,resolved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="execution_id"/>
                            <field name="task_id"/>
                            <field name="stop_line_id"/>
                            <field name="reported_by"/>
                        </group>
                        <group>
                            <field name="report_datetime"/>
                            <field name="issue_type"/>
                            <field name="severity"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Тайлбар">
                            <field name="description"/>
                        </page>
                        <page string="Зураг / хавсралт">
                            <field name="photo_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_mfo_issue_report_search" model="ir.ui.view">
        <field name="name">mfo.issue.report.search</field>
        <field name="model">mfo.issue.report</field>
        <field name="arch" type="xml">
            <search string="Хяналтын тайлан">
                <field name="name"/>
                <field name="execution_id"/>
                <field name="issue_type"/>
                <field name="reported_by"/>
                <filter name="new" string="Шинэ" domain="[('state', '=', 'new')]"/>
                <filter name="high" string="Ноцтой" domain="[('severity', 'in', ['high', 'critical'])]"/>
                <group>
                    <filter name="group_state" string="Төлөв" context="{'group_by': 'state'}"/>
                    <filter name="group_issue_type" string="Асуудлын төрөл" context="{'group_by': 'issue_type'}"/>
                    <filter name="group_severity" string="Ноцтой байдал" context="{'group_by': 'severity'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mfo_issue_report" model="ir.actions.act_window">
        <field name="name">Хяналтын тайлан</field>
        <field name="res_model">mfo.issue.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mfo_issue_report_search"/>
    </record>
</odoo>
