            <field name="model_id" ref="model_municipal_improvement_material_line"/>
            <field name="domain_force">['|', '|', ('department_id', '=', user.employee_id.department_id.id), ('department_id.manager_id.user_id', '=', user.id), ('activity_id.reviewer_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_improvement_field_engineer')), (4, ref('group_improvement_engineer')), (4, ref('group_improvement_manager'))]"/>
        </record>

        <record id="rule_improvement_material_manager_all" model="ir.rule">
            <field name="name">Improvement material managers all</field>
            <field name="model_id" ref="model_municipal_improvement_material_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_environment_manager')), (4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
