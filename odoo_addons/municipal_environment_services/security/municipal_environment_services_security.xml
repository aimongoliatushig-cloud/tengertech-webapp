            <field name="groups" eval="[(4, ref('group_green_engineer')), (4, ref('group_green_master'))]"/>
        </record>

        <record id="rule_green_activity_worker_assigned" model="ir.rule">
            <field name="name">Green activity worker assigned</field>
            <field name="model_id" ref="model_municipal_green_activity"/>
            <field name="domain_force">['|', ('assigned_user_id', '=', user.id), ('assigned_employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_environment_worker'))]"/>
        </record>

        <record id="rule_green_activity_department" model="ir.rule">
            <field name="name">Green activity department scoped</field>
            <field name="model_id" ref="model_municipal_green_activity"/>
            <field name="domain_force">['|', '|', '|', ('department_id', '=', user.employee_id.department_id.id), ('department_id.manager_id.user_id', '=', user.id), ('assigned_user_id', '=', user.id), ('reviewer_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_green_engineer')), (4, ref('group_green_master'))]"/>
        </record>

        <record id="rule_green_activity_manager_all" model="ir.rule">
            <field name="name">Green activity managers all</field>
            <field name="model_id" ref="model_municipal_green_activity"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_environment_manager')), (4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_improvement_area_manager_all" model="ir.rule">
