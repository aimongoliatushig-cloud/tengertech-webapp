            <field name="model_id" ref="model_municipal_improvement_object"/>
            <field name="domain_force">['|', '|', ('department_id', '=', user.employee_id.department_id.id), ('department_id.manager_id.user_id', '=', user.id), ('responsible_employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_improvement_field_engineer')), (4, ref('group_improvement_engineer')), (4, ref('group_improvement_manager')), (4, ref('group_improvement_welder'))]"/>
        </record>

        <record id="rule_improvement_activity_worker_assigned" model="ir.rule">
            <field name="name">Improvement activity worker assigned</field>
            <field name="model_id" ref="model_municipal_improvement_activity"/>
