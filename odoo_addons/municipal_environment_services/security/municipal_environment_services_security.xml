<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_environment_services" model="res.groups.privilege">
        <field name="name">Ногоон байгууламж, тохижилт</field>
        <field name="sequence">16</field>
        <field name="category_id" ref="base.module_category_services_project"/>
    </record>

    <record id="group_environment_worker" model="res.groups">
        <field name="name">Талбайн ажилтан</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_worker'))]"/>
    </record>

    <record id="group_green_engineer" model="res.groups">
        <field name="name">Ногоон байгууламжийн инженер</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_environment_worker')), (4, ref('municipal_core.group_municipal_master'))]"/>
    </record>

    <record id="group_green_master" model="res.groups">
        <field name="name">Ногоон байгууламжийн мастер</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_green_engineer'))]"/>
    </record>

    <record id="group_improvement_welder" model="res.groups">
        <field name="name">Гагнуурчин</field>
        <field name="sequence">40</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_environment_worker'))]"/>
    </record>

    <record id="group_improvement_field_engineer" model="res.groups">
        <field name="name">Даамал, талбайн инженер</field>
        <field name="sequence">50</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_environment_worker')), (4, ref('municipal_core.group_municipal_master'))]"/>
    </record>

    <record id="group_improvement_engineer" model="res.groups">
        <field name="name">Тохижилтын инженер</field>
        <field name="sequence">52</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_improvement_field_engineer'))]"/>
    </record>

    <record id="group_improvement_manager" model="res.groups">
        <field name="name">Тохижилтын хэлтсийн дарга</field>
        <field name="sequence">60</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_green_master')), (4, ref('group_improvement_field_engineer')), (4, ref('municipal_core.group_municipal_department_head'))]"/>
    </record>

    <record id="group_environment_manager" model="res.groups">
        <field name="name">Ногоон байгууламж, тохижилтын менежер</field>
        <field name="sequence">70</field>
        <field name="privilege_id" ref="res_groups_privilege_environment_services"/>
        <field name="implied_ids" eval="[(4, ref('group_improvement_manager')), (4, ref('municipal_core.group_municipal_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="rule_green_location_manager_all" model="ir.rule">
            <field name="name">Green location managers all</field>
            <field name="model_id" ref="model_municipal_green_location"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_environment_manager')), (4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_green_location_department" model="ir.rule">
            <field name="name">Green location department scoped</field>
            <field name="model_id" ref="model_municipal_green_location"/>
            <field name="domain_force">['|', '|', ('department_id', '=', user.employee_id.department_id.id), ('department_id.manager_id.user_id', '=', user.id), ('responsible_employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_green_engineer')), (4, ref('group_green_master'))]"/>
        </record>

        <record id="rule_green_asset_manager_all" model="ir.rule">
            <field name="name">Green asset managers all</field>
            <field name="model_id" ref="model_municipal_green_asset"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_environment_manager')), (4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

