<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_improvement_area_list" model="ir.ui.view">
        <field name="name">municipal.improvement.area.list</field>
        <field name="model">municipal.improvement.area</field>
        <field name="arch" type="xml">
            <list string="Тохижилтын талбай">
                <field name="name"/>
                <field name="code"/>
                <field name="area_type"/>
                <field name="department_id"/>
                <field name="responsible_employee_id"/>
                <field name="district"/>
                <field name="khoroo"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_improvement_area_form" model="ir.ui.view">
        <field name="name">municipal.improvement.area.form</field>
        <field name="model">municipal.improvement.area</field>
        <field name="arch" type="xml">
            <form string="Тохижилтын талбай">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="area_type"/>
                            <field name="department_id"/>
                            <field name="responsible_employee_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="district"/>
                            <field name="khoroo"/>
                            <field name="address"/>
                            <field name="gps_latitude"/>
                            <field name="gps_longitude"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Объектууд">
                            <field name="object_ids" context="{'default_area_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="object_type"/>
                                    <field name="material"/>
                                    <field name="condition"/>
                                    <field name="responsible_employee_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Тохижилтын ажил">
                            <field name="activity_ids" context="{'default_area_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="activity_type"/>
                                    <field name="assigned_employee_id"/>
                                    <field name="planned_date"/>
                                    <field name="actual_quantity"/>
                                    <field name="unit"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Зураг">
                            <field name="photo_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Тайлбар">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_improvement_area_search" model="ir.ui.view">
        <field name="name">municipal.improvement.area.search</field>
        <field name="model">municipal.improvement.area</field>
        <field name="arch" type="xml">
            <search string="Тохижилтын талбай">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="district"/>
                <field name="khoroo"/>
                <filter name="active" string="Идэвхтэй" domain="[('active', '=', True)]"/>
                <group>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                    <filter name="group_type" string="Талбайн төрөл" context="{'group_by': 'area_type'}"/>
                    <filter name="group_district" string="Дүүрэг" context="{'group_by': 'district'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_municipal_improvement_object_list" model="ir.ui.view">
        <field name="name">municipal.improvement.object.list</field>
        <field name="model">municipal.improvement.object</field>
        <field name="arch" type="xml">
            <list string="Тохижилтын объект" decoration-danger="condition == 'damaged'" decoration-warning="condition == 'needs_repair'" decoration-muted="not active">
                <field name="name"/>
                <field name="code"/>
                <field name="area_id"/>
                <field name="department_id"/>
                <field name="object_type"/>
                <field name="material"/>
                <field name="installed_date"/>
                <field name="condition"/>
                <field name="responsible_employee_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_improvement_object_form" model="ir.ui.view">
        <field name="name">municipal.improvement.object.form</field>
        <field name="model">municipal.improvement.object</field>
        <field name="arch" type="xml">
            <form string="Тохижилтын объект">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="area_id"/>
                            <field name="department_id" readonly="1"/>
                            <field name="object_type"/>
                            <field name="material"/>
                        </group>
                        <group>
                            <field name="installed_date"/>
                            <field name="condition"/>
                            <field name="responsible_employee_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Зураг">
                            <field name="photo_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Ажлын түүх">
                            <field name="activity_ids" context="{'default_object_id': id, 'default_area_id': area_id}">
                                <list>
                                    <field name="name"/>
                                    <field name="activity_type"/>
                                    <field name="planned_date"/>
                                    <field name="actual_quantity"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Тайлбар">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_improvement_object_search" model="ir.ui.view">
        <field name="name">municipal.improvement.object.search</field>
        <field name="model">municipal.improvement.object</field>
        <field name="arch" type="xml">
            <search string="Тохижилтын объект">
                <field name="name"/>
                <field name="code"/>
                <field name="area_id"/>
                <field name="department_id"/>
                <field name="object_type"/>
                <field name="condition"/>
                <filter name="needs_repair" string="Засвар шаардлагатай" domain="[('condition', '=', 'needs_repair')]"/>
                <filter name="damaged" string="Гэмтсэн" domain="[('condition', '=', 'damaged')]"/>
                <group>
                    <filter name="group_area" string="Талбай" context="{'group_by': 'area_id'}"/>
                    <filter name="group_type" string="Объектын төрөл" context="{'group_by': 'object_type'}"/>
                    <filter name="group_condition" string="Төлөв" context="{'group_by': 'condition'}"/>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_municipal_improvement_activity_list" model="ir.ui.view">
        <field name="name">municipal.improvement.activity.list</field>
        <field name="model">municipal.improvement.activity</field>
        <field name="arch" type="xml">
            <list string="Тохижилтын ажил" decoration-danger="state == 'returned'" decoration-success="state in ('approved', 'done')" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="activity_type"/>
                <field name="area_id"/>
                <field name="object_id"/>
                <field name="department_id"/>
                <field name="assigned_employee_id"/>
                <field name="field_engineer_id"/>
                <field name="reviewer_id"/>
                <field name="planned_date"/>
                <field name="actual_quantity"/>
                <field name="unit"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_improvement_activity_form" model="ir.ui.view">
        <field name="name">municipal.improvement.activity.form</field>
        <field name="model">municipal.improvement.activity</field>
        <field name="arch" type="xml">
            <form string="Тохижилтын ажил">
                <header>
                    <button name="action_plan" string="Төлөвлөх" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_assign" string="Оноох" type="object" class="btn-primary" invisible="state not in ('draft', 'planned')"/>
                    <button name="action_start" string="Эхлүүлэх" type="object" class="btn-primary" invisible="state != 'assigned'"/>
                    <button name="action_submit" string="Тайлан илгээх" type="object" invisible="state not in ('assigned', 'in_progress', 'returned')"/>
                    <button name="action_review" string="Хяналтад авах" type="object" invisible="state != 'submitted'"/>
                    <button name="action_return" string="Буцаах" type="object" invisible="state not in ('submitted', 'under_review')"/>
                    <button name="action_approve" string="Батлах" type="object" class="btn-primary" invisible="state != 'under_review'"/>
                    <button name="action_done" string="Дуусгах" type="object" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_cancel" string="Цуцлах" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Ноорог болгох" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,assigned,in_progress,submitted,under_review,returned,approved,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="activity_type"/>
                            <field name="area_id"/>
                            <field name="object_id"/>
                            <field name="department_id" readonly="1"/>
                            <field name="work_id"/>
                        </group>
                        <group>
                            <field name="assigned_user_id"/>
                            <field name="assigned_employee_id"/>
                            <field name="field_engineer_id"/>
                            <field name="reviewer_id"/>
                            <field name="planned_date"/>
                            <field name="start_datetime"/>
                            <field name="done_datetime"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="planned_quantity"/>
                            <field name="actual_quantity"/>
                            <field name="unit"/>
                        </group>
                        <group>
                            <field name="requires_photo"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="rejected_by" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Материалын хэрэгцээ">
                            <field name="material_line_ids" context="{'default_activity_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="unit"/>
                                    <field name="estimated_unit_cost"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Тайлбар">
                            <field name="description"/>
                        </page>
                        <page string="Гүйцэтгэлийн тайлан">
                            <field name="report_note"/>
                            <field name="photo_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Буцаалт">
                            <field name="rejection_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_improvement_activity_search" model="ir.ui.view">
        <field name="name">municipal.improvement.activity.search</field>
        <field name="model">municipal.improvement.activity</field>
        <field name="arch" type="xml">
            <search string="Тохижилтын ажил">
                <field name="name"/>
                <field name="area_id"/>
                <field name="object_id"/>
                <field name="department_id"/>
                <field name="assigned_employee_id"/>
                <field name="field_engineer_id"/>
                <filter name="my_work" string="Миний ажил" domain="['|', '|', ('assigned_user_id', '=', uid), ('assigned_employee_id.user_id', '=', uid), ('field_engineer_id.user_id', '=', uid)]"/>
                <filter name="under_review" string="Хяналтад" domain="[('state', '=', 'under_review')]"/>
                <filter name="returned" string="Буцаагдсан" domain="[('state', '=', 'returned')]"/>
                <filter name="welding" string="Гагнуур" domain="[('activity_type', '=', 'welding')]"/>
                <group>
                    <filter name="group_state" string="Төлөв" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Ажлын төрөл" context="{'group_by': 'activity_type'}"/>
                    <filter name="group_area" string="Талбай" context="{'group_by': 'area_id'}"/>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_municipal_improvement_material_line_list" model="ir.ui.view">
        <field name="name">municipal.improvement.material.line.list</field>
        <field name="model">municipal.improvement.material.line</field>
        <field name="arch" type="xml">
            <list string="Материалын хэрэгцээ">
                <field name="activity_id"/>
                <field name="department_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="estimated_unit_cost"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_improvement_material_line_form" model="ir.ui.view">
        <field name="name">municipal.improvement.material.line.form</field>
        <field name="model">municipal.improvement.material.line</field>
        <field name="arch" type="xml">
            <form string="Материалын хэрэгцээ">
                <sheet>
                    <group>
                        <field name="activity_id"/>
                        <field name="department_id" readonly="1"/>
                        <field name="name"/>
                        <field name="quantity"/>
                        <field name="unit"/>
                        <field name="estimated_unit_cost"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_municipal_improvement_area" model="ir.actions.act_window">
        <field name="name">Тохижилтын талбай</field>
        <field name="res_model">municipal.improvement.area</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_improvement_area_search"/>
    </record>

    <record id="action_municipal_improvement_object" model="ir.actions.act_window">
        <field name="name">Тохижилтын объект</field>
        <field name="res_model">municipal.improvement.object</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_improvement_object_search"/>
    </record>

    <record id="action_municipal_improvement_activity" model="ir.actions.act_window">
        <field name="name">Тохижилтын ажил</field>
        <field name="res_model">municipal.improvement.activity</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_improvement_activity_search"/>
    </record>

    <record id="action_municipal_improvement_my_activity" model="ir.actions.act_window">
        <field name="name">Миний тохижилтын ажил</field>
        <field name="res_model">municipal.improvement.activity</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', '|', ('assigned_user_id', '=', uid), ('assigned_employee_id.user_id', '=', uid), ('field_engineer_id.user_id', '=', uid)]</field>
        <field name="search_view_id" ref="view_municipal_improvement_activity_search"/>
    </record>

    <record id="action_municipal_improvement_under_review" model="ir.actions.act_window">
        <field name="name">Хяналтад байгаа тохижилтын ажил</field>
        <field name="res_model">municipal.improvement.activity</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'under_review')]</field>
        <field name="search_view_id" ref="view_municipal_improvement_activity_search"/>
    </record>

    <record id="action_municipal_improvement_material_line" model="ir.actions.act_window">
        <field name="name">Материалын хэрэгцээ</field>
        <field name="res_model">municipal.improvement.material.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
