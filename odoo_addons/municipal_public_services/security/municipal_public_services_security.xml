<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_municipal_complaint_manager" model="res.groups">
        <field name="name">Иргэний гомдол хариуцагч</field>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_worker'))]"/>
    </record>

    <data noupdate="1">
        <record id="rule_complaint_assigned_user" model="ir.rule">
            <field name="name">Complaint assigned user</field>
            <field name="model_id" ref="model_municipal_complaint"/>
            <field name="domain_force">['|', ('assigned_user_id', '=', user.id), ('received_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_municipal_complaint_manager')), (4, ref('municipal_core.group_municipal_public_relations'))]"/>
        </record>

        <record id="rule_complaint_department_head" model="ir.rule">
            <field name="name">Complaint department head own department</field>
            <field name="model_id" ref="model_municipal_complaint"/>
            <field name="domain_force">[('department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_department_head'))]"/>
        </record>

        <record id="rule_complaint_all_managers" model="ir.rule">
            <field name="name">Complaint all managers</field>
            <field name="model_id" ref="model_municipal_complaint"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_audit_log_managers" model="ir.rule">
            <field name="name">Audit log managers read</field>
            <field name="model_id" ref="model_municipal_audit_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin')), (4, ref('municipal_core.group_municipal_it'))]"/>
        </record>
    </data>
</odoo>
