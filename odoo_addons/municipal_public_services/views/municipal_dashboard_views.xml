<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_dashboard_snapshot_list" model="ir.ui.view">
        <field name="name">municipal.dashboard.snapshot.list</field>
        <field name="model">municipal.dashboard.snapshot</field>
        <field name="arch" type="xml">
            <list string="Dashboard snapshot">
                <field name="generated_at"/>
                <field name="name"/>
                <field name="dashboard_type"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_dashboard_snapshot_form" model="ir.ui.view">
        <field name="name">municipal.dashboard.snapshot.form</field>
        <field name="model">municipal.dashboard.snapshot</field>
        <field name="arch" type="xml">
            <form string="Dashboard snapshot">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="dashboard_type"/>
                        <field name="generated_at"/>
                        <field name="company_id"/>
                    </group>
                    <field name="data_json"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_municipal_dashboard_snapshot" model="ir.actions.act_window">
        <field name="name">Dashboard snapshot</field>
        <field name="res_model">municipal.dashboard.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
