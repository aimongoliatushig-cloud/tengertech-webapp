<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_complaint_list" model="ir.ui.view">
        <field name="name">municipal.complaint.list</field>
        <field name="model">municipal.complaint</field>
        <field name="arch" type="xml">
            <list string="Иргэний гомдол" decoration-success="state == 'resolved'" decoration-warning="state in ('new', 'assigned')" decoration-muted="state in ('rejected', 'cancelled')">
                <field name="name"/>
                <field name="complaint_type"/>
                <field name="location_text"/>
                <field name="department_id"/>
                <field name="assigned_user_id"/>
                <field name="work_id"/>
                <field name="state"/>
                <field name="resolved_date"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_complaint_form" model="ir.ui.view">
        <field name="name">municipal.complaint.form</field>
        <field name="model">municipal.complaint</field>
        <field name="arch" type="xml">
            <form string="Иргэний гомдол">
                <header>
                    <button name="action_assign" string="Хуваарилах" type="object" invisible="state != 'new'"/>
                    <button name="action_create_work" string="Ажил үүсгэх" type="object" invisible="work_id"/>
                    <button name="action_start" string="Шийдвэрлэж эхлэх" type="object" class="btn-primary" invisible="state not in ('assigned', 'new')"/>
                    <button name="action_resolve" string="Шийдвэрлэх" type="object" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_reject" string="Татгалзах" type="object" invisible="state in ('resolved', 'rejected', 'cancelled')"/>
                    <button name="action_cancel" string="Цуцлах" type="object" invisible="state in ('resolved', 'rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,assigned,in_progress,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="complainant_name"/>
                            <field name="complainant_phone"/>
                            <field name="complaint_type"/>
                            <field name="received_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="assigned_user_id"/>
                            <field name="work_id" readonly="1"/>
                            <field name="resolved_by" readonly="1"/>
                            <field name="resolved_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="location_text"/>
                        <field name="gps_latitude"/>
                        <field name="gps_longitude"/>
                    </group>
                    <notebook>
                        <page string="Гомдол">
                            <field name="description"/>
                        </page>
                        <page string="Шийдвэрлэлт">
                            <field name="resolution_note"/>
                        </page>
                        <page string="Зураг">
                            <field name="photo_ids" widget="many2many_binary"/>
                        </page>
                        <page string="QR">
                            <field name="qr_token" readonly="1"/>
                            <field name="qr_url" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_complaint_search" model="ir.ui.view">
        <field name="name">municipal.complaint.search</field>
        <field name="model">municipal.complaint</field>
        <field name="arch" type="xml">
            <search string="Иргэний гомдол">
                <field name="name"/>
                <field name="complaint_type"/>
                <field name="department_id"/>
                <field name="assigned_user_id"/>
                <filter name="new" string="Шинэ" domain="[('state', '=', 'new')]"/>
                <filter name="in_progress" string="Шийдвэрлэж байна" domain="[('state', '=', 'in_progress')]"/>
                <filter name="resolved" string="Шийдвэрлэсэн" domain="[('state', '=', 'resolved')]"/>
                <group>
                    <filter name="group_state" string="Төлөв" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Төрөл" context="{'group_by': 'complaint_type'}"/>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_municipal_complaint" model="ir.actions.act_window">
        <field name="name">Иргэний гомдол</field>
        <field name="res_model">municipal.complaint</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_complaint_search"/>
    </record>
</odoo>
