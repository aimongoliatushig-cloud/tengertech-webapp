<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_work_report_list" model="ir.ui.view">
        <field name="name">municipal.work.report.list</field>
        <field name="model">municipal.work.report</field>
        <field name="arch" type="xml">
            <list string="Ажлын тайлан" decoration-danger="state == 'returned'" decoration-success="state == 'approved'">
                <field name="report_datetime"/>
                <field name="work_id"/>
                <field name="employee_id"/>
                <field name="user_id"/>
                <field name="actual_quantity"/>
                <field name="unit_of_measure"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_work_report_form" model="ir.ui.view">
        <field name="name">municipal.work.report.form</field>
        <field name="model">municipal.work.report</field>
        <field name="arch" type="xml">
            <form string="Ажлын тайлан">
                <header>
                    <button name="action_submit" string="Илгээх" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_review" string="Хяналтад авах" type="object" invisible="state != 'submitted'"/>
                    <button name="action_return" string="Буцаах" type="object" invisible="state not in ('submitted', 'under_review')"/>
                    <button name="action_approve" string="Батлах" type="object" class="btn-primary" invisible="state != 'under_review'"/>
                    <button name="action_reset_to_draft" string="Ноорог болгох" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,under_review,returned,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="work_id"/>
                            <field name="employee_id"/>
                            <field name="user_id"/>
                            <field name="report_datetime"/>
                        </group>
                        <group>
                            <field name="actual_quantity"/>
                            <field name="unit_of_measure"/>
                            <field name="location_text"/>
                            <field name="gps_latitude"/>
                            <field name="gps_longitude"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Тайлбар">
                            <field name="description"/>
                            <field name="delay_reason"/>
                        </page>
                        <page string="Зураг / хавсралт">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="Хяналт">
                            <group>
                                <field name="rejection_reason"/>
                                <field name="reviewed_by" readonly="1"/>
                                <field name="approved_by" readonly="1"/>
                                <field name="rejected_by" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_work_report_search" model="ir.ui.view">
        <field name="name">municipal.work.report.search</field>
        <field name="model">municipal.work.report</field>
        <field name="arch" type="xml">
            <search string="Ажлын тайлан">
                <field name="work_id"/>
                <field name="employee_id"/>
                <field name="user_id"/>
                <filter name="my_reports" string="Миний тайлан" domain="['|', ('user_id', '=', uid), ('employee_id.user_id', '=', uid)]"/>
                <filter name="submitted" string="Илгээсэн" domain="[('state', '=', 'submitted')]"/>
                <filter name="under_review" string="Хяналтад" domain="[('state', '=', 'under_review')]"/>
                <filter name="returned" string="Буцаагдсан" domain="[('state', '=', 'returned')]"/>
                <group>
                    <filter name="group_state" string="Төлөв" context="{'group_by': 'state'}"/>
                    <filter name="group_work" string="Ажил" context="{'group_by': 'work_id'}"/>
                    <filter name="group_employee" string="Ажилтан" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_municipal_work_report" model="ir.actions.act_window">
        <field name="name">Ажлын тайлан</field>
        <field name="res_model">municipal.work.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_work_report_search"/>
    </record>
</odoo>
