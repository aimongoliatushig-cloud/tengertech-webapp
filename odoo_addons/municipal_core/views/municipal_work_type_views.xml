<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_work_type_list" model="ir.ui.view">
        <field name="name">municipal.work.type.list</field>
        <field name="model">municipal.work.type</field>
        <field name="arch" type="xml">
            <list string="Ажлын төрөл">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="default_requires_photo"/>
                <field name="default_requires_approval"/>
                <field name="default_unit_of_measure"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_work_type_form" model="ir.ui.view">
        <field name="name">municipal.work.type.form</field>
        <field name="model">municipal.work.type</field>
        <field name="arch" type="xml">
            <form string="Ажлын төрөл">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="default_requires_photo"/>
                            <field name="default_requires_approval"/>
                            <field name="default_unit_of_measure"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_municipal_work_type_search" model="ir.ui.view">
        <field name="name">municipal.work.type.search</field>
        <field name="model">municipal.work.type</field>
        <field name="arch" type="xml">
            <search string="Ажлын төрөл">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <filter name="active" string="Идэвхтэй" domain="[('active', '=', True)]"/>
                <filter name="requires_photo" string="Зураг шаарддаг" domain="[('default_requires_photo', '=', True)]"/>
                <group>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_municipal_work_type" model="ir.actions.act_window">
        <field name="name">Ажлын төрөл</field>
        <field name="res_model">municipal.work.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_municipal_work_type_search"/>
    </record>
</odoo>
