<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_push_subscription_own" model="ir.rule">
            <field name="name">Push subscription own device</field>
            <field name="model_id" ref="model_tengertech_push_subscription"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_push_subscription_manager_all" model="ir.rule">
            <field name="name">Push subscription managers all</field>
            <field name="model_id" ref="model_tengertech_push_subscription"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_push_event_manager_all" model="ir.rule">
            <field name="name">Push event managers all</field>
            <field name="model_id" ref="model_tengertech_push_event"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_manager')), (4, ref('municipal_core.group_municipal_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>
    </data>
</odoo>
