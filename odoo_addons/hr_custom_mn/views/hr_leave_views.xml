<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_form_hr_custom_mn" model="ir.ui.view">
        <field name="name">hr.leave.form.hr.custom.mn</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <notebook>
                    <page string="MN зөвшөөрлийн түүх">
                        <group>
                            <field name="x_mn_approval_step"/>
                        </group>
                        <field name="x_mn_history_ids">
                            <list create="0" edit="0">
                                <field name="date"/>
                                <field name="action_type"/>
                                <field name="old_state"/>
                                <field name="new_state"/>
                                <field name="user_id"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>

    <record id="view_hr_leave_list_hr_custom_mn" model="ir.ui.view">
        <field name="name">hr.leave.list.hr.custom.mn</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="x_mn_approval_step" widget="badge" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
