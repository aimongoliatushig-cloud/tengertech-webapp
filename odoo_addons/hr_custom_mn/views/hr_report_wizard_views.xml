<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_custom_mn_report_wizard_form" model="ir.ui.view">
        <field name="name">hr.custom.mn.report.wizard.form</field>
        <field name="model">hr.custom.mn.report.wizard</field>
        <field name="arch" type="xml">
            <form string="HR тайлан">
                <sheet>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="output_format"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate_report" type="object" string="Тайлан гаргах" class="btn-primary"/>
                    <button string="Хаах" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_custom_mn_report_wizard" model="ir.actions.act_window">
        <field name="name">HR тайлан</field>
        <field name="res_model">hr.custom.mn.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
