<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_custom_mn_performance_list" model="ir.ui.view">
        <field name="name">hr.custom.mn.performance.list</field>
        <field name="model">hr.custom.mn.performance</field>
        <field name="arch" type="xml">
            <list string="Гүйцэтгэлийн үнэлгээ">
                <field name="evaluation_month"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="kpi_score"/>
                <field name="task_completion_percent"/>
                <field name="discipline_score"/>
                <field name="promotion_recommendation"/>
            </list>
        </field>
    </record>

    <record id="view_hr_custom_mn_performance_form" model="ir.ui.view">
        <field name="name">hr.custom.mn.performance.form</field>
        <field name="model">hr.custom.mn.performance</field>
        <field name="arch" type="xml">
            <form string="Гүйцэтгэлийн үнэлгээ">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="evaluation_month"/>
                            <field name="promotion_recommendation"/>
                        </group>
                        <group>
                            <field name="kpi_score"/>
                            <field name="task_completion_percent"/>
                            <field name="discipline_score"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Сарын үнэлгээ">
                            <field name="monthly_evaluation"/>
                        </page>
                        <page string="Шагнал">
                            <field name="reward_ids" context="{'default_employee_id': employee_id}">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="order_no"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Сануулга">
                            <field name="warning_ids" context="{'default_employee_id': employee_id}">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="severity"/>
                                    <field name="order_no"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_custom_mn_performance_search" model="ir.ui.view">
        <field name="name">hr.custom.mn.performance.search</field>
        <field name="model">hr.custom.mn.performance</field>
        <field name="arch" type="xml">
            <search string="Гүйцэтгэлийн үнэлгээ">
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter name="recommend" string="Дэвшүүлэх саналтай" domain="[('promotion_recommendation', 'in', ['recommend', 'strong'])]"/>
                <group>
                    <filter name="group_department" string="Хэлтэс" context="{'group_by': 'department_id'}"/>
                    <filter name="group_employee" string="Ажилтан" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_month" string="Сар" context="{'group_by': 'evaluation_month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_custom_mn_performance" model="ir.actions.act_window">
        <field name="name">Гүйцэтгэлийн үнэлгээ</field>
        <field name="res_model">hr.custom.mn.performance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_custom_mn_performance_search"/>
    </record>
</odoo>
