<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_municipal_hr_clearance_sheet_tree" model="ir.ui.view">
        <field name="name">municipal.hr.clearance.sheet.tree</field>
        <field name="model">municipal.hr.clearance.sheet</field>
        <field name="arch" type="xml">
            <list string="Тойрох хуудас">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="saved_date"/>
                <field name="section"/>
                <field name="state"/>
                <field name="responsible_user_id"/>
            </list>
        </field>
    </record>

    <record id="view_municipal_hr_clearance_sheet_form" model="ir.ui.view">
        <field name="name">municipal.hr.clearance.sheet.form</field>
        <field name="model">municipal.hr.clearance.sheet</field>
        <field name="arch" type="xml">
            <form string="Тойрох хуудас">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="job_id"/>
                        </group>
                        <group>
                            <field name="saved_date"/>
                            <field name="section"/>
                            <field name="state"/>
                            <field name="responsible_user_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_municipal_hr_clearance_sheet" model="ir.actions.act_window">
        <field name="name">Тойрох хуудас</field>
        <field name="res_model">municipal.hr.clearance.sheet</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
