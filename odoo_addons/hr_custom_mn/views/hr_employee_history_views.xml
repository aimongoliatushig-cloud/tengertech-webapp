<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_custom_mn_employee_history_list" model="ir.ui.view">
        <field name="name">hr.custom.mn.employee.history.list</field>
        <field name="model">hr.custom.mn.employee.history</field>
        <field name="arch" type="xml">
            <list string="Ажилтны үйлдлийн түүх" create="0" edit="0">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="action_type"/>
                <field name="old_department_id"/>
                <field name="new_department_id"/>
                <field name="old_job_id"/>
                <field name="new_job_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_custom_mn_employee_history_form" model="ir.ui.view">
        <field name="name">hr.custom.mn.employee.history.form</field>
        <field name="model">hr.custom.mn.employee.history</field>
        <field name="arch" type="xml">
            <form string="Ажилтны үйлдлийн түүх" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="action_type"/>
                            <field name="date"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="old_department_id"/>
                            <field name="new_department_id"/>
                            <field name="old_job_id"/>
                            <field name="new_job_id"/>
                            <field name="old_manager_id"/>
                            <field name="new_manager_id"/>
                            <field name="old_grade_rank"/>
                            <field name="new_grade_rank"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hr_custom_mn_employee_history" model="ir.actions.act_window">
        <field name="name">Ажилтны үйлдлийн түүх</field>
        <field name="res_model">hr.custom.mn.employee.history</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
