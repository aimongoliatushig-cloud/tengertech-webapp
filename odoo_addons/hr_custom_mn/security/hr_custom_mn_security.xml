<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_hr_custom_mn" model="res.groups.privilege">
        <field name="name">HR Management MN</field>
        <field name="sequence">11</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <record id="group_hr_custom_mn_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="sequence">5</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_custom_mn"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hr_custom_mn_manager" model="res.groups">
        <field name="name">Department Manager</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_custom_mn"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_custom_mn_employee')), (4, ref('hr_holidays.group_hr_holidays_responsible'))]"/>
    </record>

    <record id="group_hr_custom_mn_officer" model="res.groups">
        <field name="name">HR Officer</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_custom_mn"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_custom_mn_manager')), (4, ref('hr.group_hr_user')), (4, ref('hr_holidays.group_hr_holidays_user'))]"/>
    </record>

    <record id="group_hr_custom_mn_admin" model="res.groups">
        <field name="name">HR Admin</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="res_groups_privilege_hr_custom_mn"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_custom_mn_officer')), (4, ref('hr.group_hr_manager')), (4, ref('hr_holidays.group_hr_holidays_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="rule_hr_employee_custom_employee_own" model="ir.rule">
            <field name="name">HR MN employee own profile</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_custom_mn_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_hr_employee_custom_manager_department" model="ir.rule">
            <field name="name">HR MN manager department employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">['|', '|', ('user_id', '=', user.id), ('parent_id.user_id', '=', user.id), ('department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_custom_mn_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_hr_employee_custom_officer_all" model="ir.rule">
            <field name="name">HR MN officers all employees</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_hr_custom_mn_officer')), (4, ref('group_hr_custom_mn_admin'))]"/>
        </record>

        <record id="rule_hr_custom_mn_performance_employee" model="ir.rule">
            <field name="name">HR MN performance employee own</field>
            <field name="model_id" ref="model_hr_custom_mn_performance"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_custom_mn_employee'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_hr_custom_mn_performance_manager" model="ir.rule">
            <field name="name">HR MN performance manager department</field>
            <field name="model_id" ref="model_hr_custom_mn_performance"/>
            <field name="domain_force">['|', ('employee_id.parent_id.user_id', '=', user.id), ('employee_id.department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_hr_custom_mn_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_hr_custom_mn_performance_officer" model="ir.rule">
