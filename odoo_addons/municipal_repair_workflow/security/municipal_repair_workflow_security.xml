<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_municipal_repair" model="res.groups.privilege">
        <field name="name">Хот тохижилтын засвар</field>
        <field name="sequence">13</field>
        <field name="category_id" ref="base.module_category_services_project"/>
    </record>

    <record id="group_repair_manager" model="res.groups">
        <field name="name">Засварын workflow менежер</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_manager'))]"/>
    </record>

    <record id="group_repair_team_lead" model="res.groups">
        <field name="name">Засварын багийн ахлагч</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_master'))]"/>
    </record>

    <record id="group_repair_mechanic" model="res.groups">
        <field name="name">Засварчин</field>
        <field name="sequence">30</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_worker'))]"/>
    </record>

    <record id="group_repair_storekeeper" model="res.groups">
        <field name="name">Нярав</field>
        <field name="sequence">40</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_worker'))]"/>
    </record>

    <record id="group_repair_finance" model="res.groups">
        <field name="name">Санхүү / нягтлан</field>
        <field name="sequence">50</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_worker'))]"/>
    </record>

    <record id="group_repair_director" model="res.groups">
        <field name="name">Захирлын баталгаа</field>
        <field name="sequence">60</field>
        <field name="privilege_id" ref="res_groups_privilege_municipal_repair"/>
        <field name="implied_ids" eval="[(4, ref('municipal_core.group_municipal_director'))]"/>
    </record>

    <data noupdate="1">
        <record id="rule_repair_mechanic_assigned" model="ir.rule">
            <field name="name">Repair mechanic assigned only</field>
            <field name="model_id" ref="model_municipal_repair_request"/>
            <field name="domain_force">['|', ('mechanic_id.user_id', '=', user.id), ('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_repair_mechanic'))]"/>
        </record>

        <record id="rule_repair_department_head" model="ir.rule">
            <field name="name">Repair department head own department</field>
            <field name="model_id" ref="model_municipal_repair_request"/>
            <field name="domain_force">[('department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('municipal_core.group_municipal_department_head'))]"/>
        </record>

        <record id="rule_repair_manager_all" model="ir.rule">
            <field name="name">Repair managers all</field>
            <field name="model_id" ref="model_municipal_repair_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_repair_manager')), (4, ref('group_repair_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_repair_team_lead_related" model="ir.rule">
            <field name="name">Repair team lead related only</field>
            <field name="model_id" ref="model_municipal_repair_request"/>
            <field name="domain_force">['|', '|', ('supervisor_id', '=', user.id), ('mechanic_id.user_id', '=', user.id), ('department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_repair_team_lead'))]"/>
        </record>

        <record id="rule_repair_part_manager_all" model="ir.rule">
            <field name="name">Repair part managers all</field>
            <field name="model_id" ref="model_municipal_repair_part_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_repair_manager')), (4, ref('group_repair_storekeeper')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>

        <record id="rule_repair_part_assigned_repair_roles" model="ir.rule">
            <field name="name">Repair part assigned repair roles</field>
            <field name="model_id" ref="model_municipal_repair_part_line"/>
            <field name="domain_force">['|', '|', ('repair_id.mechanic_id.user_id', '=', user.id), ('repair_id.supervisor_id', '=', user.id), ('repair_id.department_id.manager_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_repair_team_lead')), (4, ref('group_repair_mechanic'))]"/>
        </record>

        <record id="rule_procurement_repair_roles" model="ir.rule">
            <field name="name">Repair procurement visible roles</field>
            <field name="model_id" ref="model_municipal_procurement_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_repair_manager')), (4, ref('group_repair_storekeeper')), (4, ref('group_repair_finance')), (4, ref('group_repair_director')), (4, ref('municipal_core.group_municipal_admin'))]"/>
        </record>
    </data>
</odoo>
