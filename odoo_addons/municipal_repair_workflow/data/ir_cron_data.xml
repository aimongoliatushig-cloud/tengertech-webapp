<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_auto_base_deadline_reminders" model="ir.cron">
        <field name="name">Авто бааз - даатгал, улсын үзлэгийн сануулга</field>
        <field name="model_id" ref="fleet.model_fleet_vehicle"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_deadline_reminders()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_garbage_weight_fetch" model="ir.cron">
        <field name="name">Авто бааз - хог ачалтын жин татах</field>
        <field name="model_id" ref="model_municipal_garbage_sync_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_fetch_weight_reports()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_garbage_fuel_fetch" model="ir.cron">
        <field name="name">Авто бааз - шатахууны мэдээлэл татах</field>
        <field name="model_id" ref="model_municipal_garbage_sync_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_fetch_fuel_reports()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
