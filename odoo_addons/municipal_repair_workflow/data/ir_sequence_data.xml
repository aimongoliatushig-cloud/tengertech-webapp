<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_municipal_repair_request" model="ir.sequence">
        <field name="name">Засварын хүсэлт</field>
        <field name="code">municipal.repair.request</field>
        <field name="prefix">REPAIR/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_municipal_procurement_request" model="ir.sequence">
        <field name="name">Худалдан авалтын хүсэлт</field>
        <field name="code">municipal.procurement.request</field>
        <field name="prefix">PROC/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
